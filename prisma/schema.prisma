generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
  DIRECTOR
}

enum SchoolStatus {
  ACTIVE
  SUSPENDED
}

model School {
  id                  String       @id @default(uuid())
  name                String       @unique
  email               String?      @unique
  city                String
  status              SchoolStatus @default(ACTIVE)
  onboardingCompleted Boolean      @default(false)
  createdAt           DateTime     @db.Timestamptz(3)
  updatedAt           DateTime     @db.Timestamptz(3)
  classes             Class[]
  students            Student[]
  users               User[]
}

model User {
  id            String         @id @default(uuid())
  image         String?
  name          String
  username      String?
  email         String?        @unique
  phone         String?        @unique
  role          UserRole       @default(ADMIN)
  emailVerified Boolean        @default(false)
  isActive      Boolean        @default(true)
  schoolId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  school        School?        @relation(fields: [schoolId], references: [id])
  sessions  Session[]
  accounts  Account[]
}

model Session {
	id        String @id
	user      User @relation(fields: [userId], references: [id])
	userId    String
	token     String @unique
	expiresAt DateTime @db.Timestamptz(3)
	ipAddress String?
	userAgent String?
	createdAt DateTime @db.Timestamptz(3)
	updatedAt DateTime @db.Timestamptz(3)
}

model Account {
	id            String @id
	user          User    @relation(fields: [userId], references: [id])
	userId        String
	accountId     String
	providerId    String
	accessToken   String?
	refreshToken  String?
	accessTokenExpiresAt DateTime? @db.Timestamptz(3)
	refreshTokenExpiresAt DateTime? @db.Timestamptz(3)
	scope         String?
	idToken       String?
	password      String?
	createdAt     DateTime @db.Timestamptz(3)
	updatedAt     DateTime @db.Timestamptz(3)
}

model Verification {
	id          String @id
	identifier  String
	value       String
	expiresAt   DateTime @db.Timestamptz(3)
	createdAt   DateTime @db.Timestamptz(3)
	updatedAt   DateTime @db.Timestamptz(3)
}

model Class {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id])
  students  Student[]
}

model Student {
  id        String   @id @default(uuid())
  matricule String   @unique
  firstname String
  lastname  String
  phone     String?
  email     String?
  average   Float?
  createdAt DateTime @default(now())
  schoolId  String
  classId   String?
  class     Class?   @relation(fields: [classId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id])
}


